# Postgres connection strings for the "oh-20221 site" Supabase project
# (ref: poicufjhjtkxtuqkzmex). Get [YOUR-PASSWORD] from Supabase ->
# Project Settings -> Database -> Database password (reset it there if
# you don't have it saved).
#
# Pooled (Transaction mode, port 6543) — used by the running app, since
# serverless/edge functions need connection pooling:
DATABASE_URL="postgresql://postgres.poicufjhjtkxtuqkzmex:[YOUR-PASSWORD]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"

# Direct (port 5432) — used only for running Prisma migrations:
DIRECT_URL="postgresql://postgres.poicufjhjtkxtuqkzmex:[YOUR-PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Optional: seed a first admin account on `npm run seed`
SEED_ADMIN_EMAIL="admin@example.org"
SEED_ADMIN_PASSWORD="change-me-now"
